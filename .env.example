# PostgreSQL
POSTGRES_DB=airbnb_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Auth0 (SPA pattern: backend validates JWTs)
AUTH0_ISSUER=https://airbnb-backend.us.auth0.com/
AUTH0_AUDIENCE=https://airbnb-api
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_CLIENT_SECRET=your_spa_client_secret
AUTH0_ROLE_LANDLORD_ID=rol_xxxxxxxxxx

# Domain
DOMAIN=airbnb.mostafadarwesh.com
